{
    "layer": "top",
    "position": "bottom",
    "height": 24,
    "spacing": 0,
    
    // --------------//
    // MODULE GROUPS //
    // --------------//
    "modules-left": [
        "custom/power",
        "hyprland/workspaces",
        "mpris"
    ],
    "modules-center": [
        "custom/clockblink"
    ],
    "modules-right": [
        "pulseaudio",
        "battery",
        "cpu",
        "memory",
        "custom/gpu",
        "custom/vram",
        //"network#download",
        //"network#upload",
        "network",
        "tray"

    ],
    
    // -------------//
    // MODULES-LEFT //
    // -------------//
   
    // (1/3) Combination of 'custom/power' & 'power-profiles-daemon'
    "custom/power": {
        "format" : "󰇙",
        //"format" : "󰣇",
		"tooltip": false,
		"menu": "on-click",
		"menu-file": "$HOME/.config/waybar/scripts/power_menu.xml", // Menu file in resources folder
		"menu-actions": {
			"shutdown": "shutdown now",
			"reboot": "reboot",
			"suspend": "systemctl suspend",
			"hibernate": "systemctl hibernate",
			"lock": "hyprlock"
		},
		"on-click-right": "hyprctl kill"
    },
    
    // (2/3) Hyprland workspaces module
    "hyprland/workspaces": {
        "format": "{windows}",
        "format-window-separator": "",
        "workspace-taskbar": {
            "enable": true,
            "update-active-window": true,
            "format": "{icon}",
            "icon-size": 20,
            "on-click-window": "${SCRIPTS}/focus-window.sh {address} {button}"
        },
        "all-outputs": true,
        "persistent-workspaces": {
            "*": [1, 2, 3, 4, 5, 6, 7, 8, 9]
        }
    },
    
    // (3/3) Media player (spotify)
    "mpris": {
        "player": "spotify",
        "format": "⏸ {artist} - {title}",
        "format-paused": "▶ {artist} - {title}",
        "max-length": 50,
        "tooltip": false,
        "on-scroll-up": "playerctl -p spotify position 10+",
        "on-scroll-down": "playerctl -p spotify position 10-",
    },
    
    
    
    // ---------------//
    // MODULES-CENTER //
    // ---------------//
       
    // (1/1) Custom blinking clock module. Weekday, day of month, hour:minute
    "custom/clockblink": {
        "exec": "~/.config/waybar/scripts/blinkclock.sh",
        "interval": 10,
        "return-type": "json",
        "format": "{text}",
        //"tooltip-format": "<big>{:%a %d-%m-%Y}</big>\n<tt><small>{calendar}</small></tt>"
    },


    
    // --------------//
    // MODULES-RIGHT //
    // --------------//
    
    // (1/10) Pulseaudio volume control with pavucontrol on click
    "pulseaudio": {
        "format": "{icon} {volume}%",
        "format-bluetooth": "{icon}  {volume}%",
        "format-icons": {
            "headphone": "",
            "hands-free": "",
            "headset": "",
            "phone": "",
            "portable": "",
            "car": "",
        },
        "on-click": "pavucontrol"
    },

    // (2/10) Battery status
    "battery": {
        "states": {
            "good": 95,
            "warning": 30,
            "critical": 15
        },
        "format": "{capacity}%",
        "tooltip-format": "Health: {health} \n{timeTo}",
        "full-at": 95,
        "format-icons": ["", "", "", "", ""],
        "format-icons-charging": ["󰢜", "󰢜", "󰢜", "󰢜", "󰢜", "󰢜", "󰢜", "󰢜", "󰢜", "󰢜"]
    },


    // (3/10) CPU usage
    "cpu": {
        "format": "{usage}%",
        "interval": 5
    },

    // (4/10) RAM usage
    "memory": {
        "format": "{used:.1f}/{total:.0f}",
        "interval": 5
    },


    // (5/10) GPU usage (NVIDIA only, requires nvidia-smi)
    "custom/gpu": {
        "exec": "nvidia-smi --query-gpu=utilization.gpu --format=csv,noheader,nounits",
        "format": "{}%",
        "interval": 5
    },

    // (6/10) VRAM usage
    "custom/vram": {
        "exec": "~/.config/waybar/scripts/vram.sh",
        "format": "{}",
        "interval": 5
    },


    // (7/10) Network Download speed
    "network#download": {
        "interval": 2,
        "format": "{bandwidthDownBits}",
        "tooltip": false
    },

    // (8/10) Network Upload speed
    "network#upload": {
        "interval": 2,
        "format": "{bandwidthUpBits}",
        "tooltip": false
    },

    // (9/10) Network status (WiFi & Ethernet)
    "network": {
        "format-wifi": " {ifname} {signalStrength}%",
        "format-ethernet": " ",
        "tooltip-format": " {ifname} via {gwaddr}",
        "format-linked": "󰈀 (No IP) ",
        "format-disconnected": " ",
        "on-click": "kitty -e nmtui",
        "on-click-right": "kitty -e bluetui"
    },

    // (10/10) Tray
    "tray": {
        "spacing": 10
    },
}
